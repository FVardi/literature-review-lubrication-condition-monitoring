	journal = {Lubricants},
	author = {Dai, Wei},
	month = sep,
	year = {2024},
	keywords = {electrical capacitance, electrical capitance, film thickness estimation, notion, review},
	pages = {329},
	file = {Full Text PDF:C\:\\Users\\au808956\\Zotero\\storage\\YV4LL2QI\\Dai - 2024 - In Situ Measurement of Grease Capacitive Film Thickness in Bearings A Review.pdf:application/pdf},
