@article{zhao_fault_2023,
	title = {Fault {Diagnosis} for {Abnormal} {Wear} of {Rolling} {Element} {Bearing} {Fusing} {Oil} {Debris} {Monitoring}},
	volume = {23},
	issn = {1424-8220},
	url = {https://www.mdpi.com/1424-8220/23/7/3402},
	doi = {10.3390/s23073402},
	abstract = {The abnormal wear of a rolling element bearing caused by early failures, such as pitting and spalling, will deteriorate the running state and reduce the life. This paper demonstrates the importance of oil debris monitoring and its effective feature extraction for bearing health assessment. In this paper, a rolling bearing-rotor test rig with forced lubrication is set up and the nonferrous contaminants with higher hardness were introduced artificially to accelerate the occurrence of pitting and spalling. The early failure and abnormal wear of rolling bearings cannot be effectively detected only through the vibration signal; the temperature and oil debris monitoring data are also collected synchronously. Two features regarding the ferrous particle size distribution are extracted and fused with vibration based-features to form a feature set. The sensitive features are extracted from the features set using the Neighborhood Component Analysis method to avoid feature redundancy. Finally, the importance of the oil debris based-features for the diagnosis of abnormal bearing wear is analyzed with different machine learning algorithms. Taking SVM classifier as an example, the experiment results show that the introduction of oil debris based-features increases the diagnostic accuracy by 15.7\%.},
	language = {en},
	number = {7},
	urldate = {2025-11-03},
	journal = {Sensors},
	author = {Zhao, Yulai and Wang, Xiaowei and Han, Shuo and Lin, Junzhe and Han, Qingkai},
	month = mar,
	year = {2023},
	keywords = {notion},
	pages = {3402},
	file = {Full Text:C\:\\Users\\au808956\\Zotero\\storage\\YSQV8ENF\\Zhao et al. - 2023 - Fault Diagnosis for Abnormal Wear of Rolling Element Bearing Fusing Oil Debris Monitoring.pdf:application/pdf},
}

